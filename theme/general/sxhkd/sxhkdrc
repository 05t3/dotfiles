# === LAUNCH PROGRAMS===

# terminal emulator
super + Return
	alacritty

# program launcher
super + d
	dmenu_run

# Launch File Manager (Thunar)
super + f
	dolphin

# Launch Browser (Firefox-esr)
super + b
	firefox-esr


# === WINDOW STATE ===


# Set Window State: Floating Mode
super + shift + space
	bspc node -t ~floating

# Set Window State: Fullscreen Mode
super + shift + f
	bspc node -t ~fullscreen

# Cycle desktop layout
super + t
	bspc desktop -l next


# === WM CONTROL ===

# Reload sxhkd (Hotkey Daemon)
super + Escape
	pkill -USR1 -x sxhkd; notify-send 'sxhkd' 'Reloaded config'

# Reload bspwm (Window Manager)
super + shift + r
	bspc wm -r; notify-send 'bspwm' 'Restarted'

# Quit bspwm (Exit Window Manager)
super + shift + q
	bspc quit

# Close Focused Window
super + q
	bspc node -c

# === WINDOW NAVIGATION ===

# Rotate Window 90° Clockwise
super + i
	bspc node -R 90

# Rotate Window 90° Counterclockwise
super + shift + i
	bspc node -R -90

# Change Focus to Left Window
super + {Left,h}
	bspc node -f west

# Change Focus to Window Below
super + {Down,j}
	bspc node -f south

# Change Focus to Window Above
super + {Up,k}
	bspc node -f north

# Change Focus to Right Window
super + {Right,l}
	bspc node -f east

# Swap Focused Window with Left Window
super + shift + {Left,h}
	bspc node -s west

# Swap Focused Window with Window Below
super + shift + {Down,j}
	bspc node -s south

# Swap Focused Window with Window Above
super + shift + {Up,k}
	bspc node -s north

# Swap Focused Window with Right Window
super + shift + {Right,l}
	bspc node -s east

# === WORKSPACES ===

# Switch to Workspace 1-10
super + {1-9,0}
	bspc desktop --focus ^{1-9,10}

# Switch to Workspace 11-12
super + {minus,equal}
	bspc desktop --focus ^{11,12}

# Move Focused Window to Workspace 1-10
super + shift + {1-9,0}
	bspc node --to-desktop ^{1-9,10}

# Move Focused Window to Workspace 11-12
super + shift + {minus,equal}
	bspc node --to-desktop ^{11,12}

# === WINDOW RESIZE ===

# Expand window width both sides
super + ctrl + {Left,h}
	bspc node -z right 40 0; bspc node -z left 40 0

# Shrink window width both sides
super + ctrl + {Right,l}
	bspc node -z right -40 0; bspc node -z left -40 0

# Resize Window: Shrink Down
super + ctrl + {Down,j}
	bspc node -z top 0 40; bspc node -z bottom 40 0

# Resize Window: Shrink Up
super + ctrl + {Up,k}
	bspc node -z top 0 -40; bspc node -z bottom -40 0

# Resize All Windows Equally
super + ctrl + equal
	bspc node @/ -B
